{
  "name": "black-lightning-server",
  "version": "1.0.0",
  "description": "Server for Black Lightning, a music recognition service",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec npx tsx server.ts",
    "build": "tsc",
    "start": "node dist/server.js"
  },
  "type": "commonjs",
  "keywords": [
    "music",
    "recognition",
    "audio",
    "fingerprinting",
    "shazam",
    "spotify",
    "apple music",
    "deezer",
    "tidal",
    "soundhound",
    "audd",
    "acoustid",
    "echoprint"
  ],
  "author": "daniel-oluwadunsin",
  "license": "ISC",
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "audio-decode": "^3.9.3",
    "bullmq": "^5.74.1",
    "chalk": "^5.6.2",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ffmpeg": "^0.0.4",
    "fft.js": "^4.0.4",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "prisma": "^7.7.0",
    "wav-decoder": "^1.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/helmet": "^0.0.48",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "fft-js": "^0.0.12",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
